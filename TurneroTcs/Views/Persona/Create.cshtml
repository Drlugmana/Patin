@model TurneroTcs.ViewModels.PersonaCrearViewModel
@{
    ViewData["Title"] = "Turnero | Crear Persona";
    var isLiderOnly = User.IsInRole("Lider") && !User.IsInRole("Admin") && !User.IsInRole("SuperAdmin");
}

@section Styles {
    <link rel="stylesheet" href="~/css/persona-create.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm persona-create-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <span class="badge bg-primary-subtle text-primary border border-primary persona-create-badge">Nuevo</span>
                        </div>
                        <div>
                            <h2 class="h4 mb-1 persona-create-title">Crear persona</h2>
                            <div class="text-muted persona-create-subtitle">Completa los datos para registrar un nuevo miembro</div>
                        </div>
                    </div>

                    <form asp-action="Create" method="post" class="mt-3">

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Nombre" class="form-label persona-create-label"></label>
                                <input asp-for="Nombre" class="form-control persona-create-input" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SegundoNombre" class="form-label persona-create-label"></label>
                                <input asp-for="SegundoNombre" class="form-control persona-create-input" />
                                <span asp-validation-for="SegundoNombre" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Apellido" class="form-label persona-create-label"></label>
                                <input asp-for="Apellido" class="form-control persona-create-input" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SegundoApellido" class="form-label persona-create-label"></label>
                                <input asp-for="SegundoApellido" class="form-control persona-create-input" />
                                <span asp-validation-for="SegundoApellido" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Ultimatix" class="form-label persona-create-label"></label>
                                <input asp-for="Ultimatix" class="form-control persona-create-input" />
                                <span asp-validation-for="Ultimatix" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="RoleName" class="form-label persona-create-label"></label>
                                <select asp-for="RoleName" asp-items="Model.Roles" class="form-select persona-create-select">
                                    <option value="">Seleccione un rol</option>
                                </select>
                                <span asp-validation-for="RoleName" class="text-danger"></span>
                            </div>

                            @if (Model.Equipos != null && Model.Equipos.Any())
                            {
                                <div class="col-md-6">
                                    <label asp-for="EquipoId" class="form-label persona-create-label"></label>
                                    @if (isLiderOnly)
                                    {
                                        <input type="hidden" asp-for="EquipoId" />
                                        <select class="form-select persona-create-select" data-equipo-select disabled>
                                            @foreach (var equipo in Model.Equipos)
                                            {
                                                <option value="@equipo.Value" selected="@(equipo.Value == Model.EquipoId ? "selected" : null)">@equipo.Text</option>
                                            }
                                        </select>
                                        <div class="form-text">Solo puedes crear personas para tu equipo.</div>
                                    }
                                    else
                                    {
                                        <select asp-for="EquipoId" asp-items="Model.Equipos" class="form-select persona-create-select" data-equipo-select>
                                            <option value="">Sin equipo</option>
                                        </select>
                                    }
                                    <span asp-validation-for="EquipoId" class="text-danger"></span>
                                </div>
                            }

                            <div class="col-md-6">
                                <label asp-for="Grupos" class="form-label persona-create-label"></label>
                                <div class="multi-select" data-grupo-wrapper>
                                    <button type="button" class="multi-select-toggle" data-grupo-toggle>
                                        Selecciona grupos
                                    </button>
                                    <div class="multi-select-menu" data-grupo-menu>
                                        <div class="multi-select-options" data-grupo-options></div>
                                    </div>
                                </div>
                                <select asp-for="Grupos" asp-items="Model.GruposNombres" class="form-select d-none" multiple data-grupo-select></select>
                                <span asp-validation-for="Grupos" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label persona-create-label"></label>
                                <input asp-for="Password" class="form-control persona-create-input" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmarPassword" class="form-label persona-create-label"></label>
                                <input asp-for="ConfirmarPassword" class="form-control persona-create-input" />
                                <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="ColorUsuario" class="form-label persona-create-label"></label>
                                <input asp-for="ColorUsuario" type="color" class="form-control form-control-color persona-create-color" value="#1f4d46" />
                                <span asp-validation-for="ColorUsuario" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary persona-create-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary persona-create-primary">Crear</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            window.AppToast?.show("No se pudo crear la persona", "danger");
        });
    </script>
}

@section Scripts {
    <script src="~/js/persona-create.js" asp-append-version="true"></script>
}
