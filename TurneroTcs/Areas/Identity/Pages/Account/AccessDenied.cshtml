@page
@model TurneroTcs.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Acceso denegado";
}

@section Styles {
    <link rel="stylesheet" href="~/css/access-denied.css" asp-append-version="true" />
}

<div class="container py-5 access-denied">
    <div class="access-denied-card">
        <div class="access-denied-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" role="img">
                <path fill="currentColor" d="M12 2a6 6 0 0 1 6 6v3h1.2a1.8 1.8 0 0 1 1.8 1.8v7.4a1.8 1.8 0 0 1-1.8 1.8H4.8A1.8 1.8 0 0 1 3 20.2v-7.4A1.8 1.8 0 0 1 4.8 11H6V8a6 6 0 0 1 6-6Zm-4 9h8V8a4 4 0 1 0-8 0v3Z"/>
            </svg>
        </div>
        <h1 class="access-denied-title">Acceso denegado</h1>
        <p class="access-denied-text">No tienes permisos para ver este recurso. Si crees que es un error, contacta al administrador.</p>
        <div class="access-denied-actions">
            <button type="button" class="btn btn-primary" id="accessDeniedBack">Volver</button>
            <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Home")">Ir al inicio</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const backButton = document.getElementById("accessDeniedBack");
        if (backButton) {
            backButton.addEventListener("click", () => {
                if (window.history.length > 1) {
                    window.history.back();
                } else {
                    window.location.href = "@Url.Action("Index", "Home")";
                }
            });
        }
    </script>
}
