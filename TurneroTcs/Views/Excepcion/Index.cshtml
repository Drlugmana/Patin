@model TurneroTcs.ViewModels.ExcepcionTurnoPersonaIndexViewModel
@{
    ViewData["Title"] = $"Turnero | Excepciones - {Model.NombreEquipo ?? "Equipo"}";
    var showCreateForm = !ViewData.ModelState.IsValid;

    // Helper para mostrar los días de la semana en texto
    string GetDiasDisplayText(string diasCsv)
    {
        if (string.IsNullOrWhiteSpace(diasCsv)) return "Todos";
        var diasNombres = new[] { "Lun", "Mar", "Mié", "Jue", "Vie", "Sab", "Dom" };
        var partes = diasCsv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var nombres = new List<string>();
        foreach (var p in partes)
        {
            if (int.TryParse(p, out var v) && v >= 0 && v < diasNombres.Length)
            {
                nombres.Add(diasNombres[v]);
            }
        }
        return nombres.Any() ? string.Join(", ", nombres) : "Todos";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/app-data-surface.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/excepcion-index.css" asp-append-version="true" />
}

<form id="excepcion-inline-token" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h2 class="h4 mb-1">Excepciones</h2>
            <div class="text-muted">Equipo: @Model.NombreEquipo</div>
        </div>
        <button class="btn app-btn-primary"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#excepcion-create-collapse"
                aria-expanded="@(showCreateForm ? "true" : "false")"
                aria-controls="excepcion-create-collapse">
            Nueva excepcion
        </button>
    </div>

    <div class="collapse @(showCreateForm ? "show" : null)" id="excepcion-create-collapse">
        <div class="card shadow-sm app-data-card mb-4">
            <div class="card-body">
                <div class="mb-3 fw-semibold">Nueva excepcion</div>
                <form asp-action="Create" asp-route-equipoId="@Model.EquipoId" method="post" class="row g-3 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EquipoId" />
                    <div asp-validation-summary="ModelOnly" class="col-12 text-danger"></div>
                    <div class="col-md-3">
                        <label asp-for="Create.PersonaId" class="form-label"></label>
                        <select asp-for="Create.PersonaId" class="form-select" data-app-select-append-to-body="true">
                            <option value="">Seleccione...</option>
                            @foreach (var persona in Model.Personas)
                            {
                                <option value="@persona.PersonaId">@persona.NombreCompleto</option>
                            }
                        </select>
                        <span asp-validation-for="Create.PersonaId" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Create.TipoTurnoId" class="form-label"></label>
                        <select asp-for="Create.TipoTurnoId" class="form-select" data-app-select-append-to-body="true">
                            <option value="">Seleccione...</option>
                            @foreach (var turno in Model.TipoTurnos)
                            {
                                <option value="@turno.TipoTurnoId">@turno.NombreTurno</option>
                            }
                        </select>
                        <span asp-validation-for="Create.TipoTurnoId" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Create.FechaInicio" class="form-label"></label>
                        <input asp-for="Create.FechaInicio" type="date" class="form-control" />
                        <span asp-validation-for="Create.FechaInicio" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Create.FechaFin" class="form-label"></label>
                        <input asp-for="Create.FechaFin" type="date" class="form-control" />
                        <span asp-validation-for="Create.FechaFin" class="text-danger"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Create.MotivoExcepcion" class="form-label"></label>
                        <input asp-for="Create.MotivoExcepcion" class="form-control" maxlength="250" />
                        <span asp-validation-for="Create.MotivoExcepcion" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Días de la semana</label>
                        <div class="d-flex flex-wrap gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia0" name="SelectedDiasSemana" value="0" />
                                <label class="form-check-label" for="dia0">Lunes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia1" name="SelectedDiasSemana" value="1" />
                                <label class="form-check-label" for="dia1">Martes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia2" name="SelectedDiasSemana" value="2" />
                                <label class="form-check-label" for="dia2">Miércoles</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia3" name="SelectedDiasSemana" value="3" />
                                <label class="form-check-label" for="dia3">Jueves</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia4" name="SelectedDiasSemana" value="4" />
                                <label class="form-check-label" for="dia4">Viernes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia5" name="SelectedDiasSemana" value="5" />
                                <label class="form-check-label" for="dia5">Sábado</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dia6" name="SelectedDiasSemana" value="6" />
                                <label class="form-check-label" for="dia6">Domingo</label>
                            </div>
                        </div>
                        <small class="form-text text-muted d-block mt-1">Si no selecciona días, aplica a todos.</small>
                    </div>
                    <div class="col-12 text-end d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#excepcion-create-collapse">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar excepcion</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="card shadow-sm app-data-card">
        <div class="card-body p-0">
            <div class="table-responsive app-data-table-wrap">
                <table class="table align-middle mb-0 app-data-table excepcion-table">
                    <thead>
                        <tr>
                            <th>Persona</th>
                            <th>Tipo de turno</th>
                            <th>Motivo</th>
                            <th>Días</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Excepciones != null && Model.Excepciones.Any())
                        {
                            foreach (var excepcion in Model.Excepciones)
                            {
                                <tr class="excepcion-row"
                                    data-excepcion-id="@excepcion.ExcepcionTurnoPersonaId"
                                    data-persona-id="@excepcion.PersonaId"
                                    data-tipo-turno-id="@excepcion.TipoTurnoId"
                                    data-motivo="@excepcion.MotivoExcepcion"
                                    data-dias="@excepcion.DiasSemana"
                                    data-inicio="@excepcion.FechaInicio.ToString("yyyy-MM-dd")"
                                    data-fin="@excepcion.FechaFin.ToString("yyyy-MM-dd")">
                                    <td>
                                        <div class="excepcion-name-wrap">
                                            <button type="button"
                                                    class="btn btn-outline-secondary excepcion-inline-edit excepcion-expand-btn"
                                                    aria-label="Expandir fila"
                                                    aria-expanded="false"
                                                    aria-controls="excepcion-edit-@excepcion.ExcepcionTurnoPersonaId">
                                                <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                    <path d="M6.7 9.3a1 1 0 0 1 1.4 0L12 13.2l3.9-3.9a1 1 0 1 1 1.4 1.4l-4.6 4.6a1 1 0 0 1-1.4 0l-4.6-4.6a1 1 0 0 1 0-1.4Z" />
                                                </svg>
                                            </button>
                                            <span data-field-display="Persona">@(excepcion.Persona?.NombreCompleto ?? "-")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span data-field-display="TipoTurno">@(excepcion.TipoTurno?.NombreTurno ?? "-")</span>
                                    </td>
                                    <td>
                                        <span data-field-display="MotivoExcepcion">@excepcion.MotivoExcepcion</span>
                                    </td>
                                    <td>
                                        <span data-field-display="DiasSemana">@GetDiasDisplayText(excepcion.DiasSemana)</span>
                                    </td>
                                    <td>
                                        <span data-field-display="FechaInicio">@excepcion.FechaInicio.ToString("yyyy-MM-dd")</span>
                                    </td>
                                    <td>
                                        <span data-field-display="FechaFin">@excepcion.FechaFin.ToString("yyyy-MM-dd")</span>
                                    </td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="btn btn-outline-danger excepcion-delete-btn"
                                                aria-label="Eliminar excepcion"
                                                title="Eliminar excepcion"
                                                data-excepcion-id="@excepcion.ExcepcionTurnoPersonaId"
                                                data-excepcion-persona="@(excepcion.Persona?.NombreCompleto ?? "esta persona")">
                                            <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 6h2v9h-2V9Zm4 0h2v9h-2V9ZM7 9h2v9H7V9Z" />
                                            </svg>
                                        </button>
                                        <span class="excepcion-inline-status" aria-live="polite"></span>
                                    </td>
                                </tr>
                                <tr class="excepcion-edit-row" data-excepcion-edit-for="@excepcion.ExcepcionTurnoPersonaId" id="excepcion-edit-@excepcion.ExcepcionTurnoPersonaId">
                                    <td colspan="6">
                                        <div class="excepcion-edit-panel">
                                            <div class="excepcion-edit-header">
                                                <div>
                                                    <strong>Editar excepcion</strong>
                                                    <span class="text-muted">Actualiza los datos y guarda cambios.</span>
                                                </div>
                                            </div>
                                            <div class="row g-3 align-items-end excepcion-edit-grid">
                                                <div class="col-md-3">
                                                    <label class="form-label excepcion-edit-label">Persona</label>
                                                    <select class="form-select excepcion-edit-input" data-field="PersonaId">
                                                        @foreach (var persona in Model.Personas)
                                                        {
                                                            <option value="@persona.PersonaId" selected="@(persona.PersonaId == excepcion.PersonaId ? "selected" : null)">@persona.NombreCompleto</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label excepcion-edit-label">Tipo de turno</label>
                                                    <select class="form-select excepcion-edit-input" data-field="TipoTurnoId">
                                                        @foreach (var turno in Model.TipoTurnos)
                                                        {
                                                            <option value="@turno.TipoTurnoId" selected="@(turno.TipoTurnoId == excepcion.TipoTurnoId ? "selected" : null)">@turno.NombreTurno</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label excepcion-edit-label">Inicio</label>
                                                    <input class="form-control excepcion-edit-input" type="date" data-field="FechaInicio" value="@excepcion.FechaInicio.ToString("yyyy-MM-dd")" />
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label excepcion-edit-label">Fin</label>
                                                    <input class="form-control excepcion-edit-input" type="date" data-field="FechaFin" value="@excepcion.FechaFin.ToString("yyyy-MM-dd")" />
                                                </div>
                                                <div class="col-md-9">
                                                    <label class="form-label excepcion-edit-label">Motivo</label>
                                                    <input class="form-control excepcion-edit-input" data-field="MotivoExcepcion" maxlength="250" value="@excepcion.MotivoExcepcion" />
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label excepcion-edit-label">Días de la semana</label>
                                                    <div class="d-flex flex-wrap gap-2 excepcion-dias-checkboxes" data-dias-csv="@excepcion.DiasSemana">
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="0" id="edit_dia0_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia0_@excepcion.ExcepcionTurnoPersonaId">Lunes</label>
                                                        </div>
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="1" id="edit_dia1_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia1_@excepcion.ExcepcionTurnoPersonaId">Martes</label>
                                                        </div>
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="2" id="edit_dia2_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia2_@excepcion.ExcepcionTurnoPersonaId">Miércoles</label>
                                                        </div>
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="3" id="edit_dia3_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia3_@excepcion.ExcepcionTurnoPersonaId">Jueves</label>
                                                        </div>
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="4" id="edit_dia4_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia4_@excepcion.ExcepcionTurnoPersonaId">Viernes</label>
                                                        </div>
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="5" id="edit_dia5_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia5_@excepcion.ExcepcionTurnoPersonaId">Sábado</label>
                                                        </div>
                                                        <div class="form-check form-check-inline">
                                                            <input class="form-check-input excepcion-dia-checkbox" type="checkbox" data-field="DiasSemana" value="6" id="edit_dia6_@excepcion.ExcepcionTurnoPersonaId" />
                                                            <label class="form-check-label" for="edit_dia6_@excepcion.ExcepcionTurnoPersonaId">Domingo</label>
                                                        </div>
                                                    </div>
                                                    <small class="form-text text-muted d-block mt-1">Si no selecciona días, aplica a todos.</small>
                                                </div>
                                            </div>
                                            <div class="excepcion-edit-actions">
                                                <button type="button" class="btn btn-outline-secondary excepcion-inline-cancel">Cancelar</button>
                                                <button type="button" class="btn btn-primary excepcion-inline-save">Guardar cambios</button>
                                                <span class="excepcion-inline-status" aria-live="polite"></span>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No hay excepciones registradas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="excepcion-delete-modal" tabindex="-1" aria-labelledby="excepcion-delete-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="excepcion-delete-modal-label">Eliminar excepcion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Deseas eliminar la excepcion de <strong data-excepcion-delete-name>esta persona</strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="excepcion-delete-form" asp-action="Delete" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="" />
                    <input type="hidden" name="equipoId" value="@Model.EquipoId" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/excepcion-inline-edit.js" asp-append-version="true"></script>
    @if (TempData["Success"] is string successMessage)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                window.AppToast?.show(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)), "success");
            });
        </script>
    }
    @if (TempData["Error"] is string errorMessage)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                window.AppToast?.show(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMessage)), "danger");
            });
        </script>
    }
}
