@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar Sesion";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-login.css" asp-append-version="true" />
}

<div class="login-shell">
    <div class="login-card-wrap">
        <div class="card login-card shadow-sm">
            <div class="card-body p-4">
                <p class="login-eyebrow">Acceso</p>
                <h1 class="h4 mb-2 login-title">@ViewData["Title"]</h1>
                <p class="text-muted mb-4 login-subtitle">Use una cuenta local para ingresar.</p>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Ultimatix" class="form-control" autocomplete="username" aria-required="true" placeholder="1111111" />
                        <label asp-for="Input.Ultimatix" class="form-label">Ultimatix</label>
                        <span asp-validation-for="Input.Ultimatix" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <button id="login-submit" type="submit" class="w-100 btn app-btn-primary">Ingresar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
