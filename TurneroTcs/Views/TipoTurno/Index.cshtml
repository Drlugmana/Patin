@model IEnumerable<TurneroTcs.Models.TipoTurno>
@{
    ViewData["Title"] = "Turnero | Tipos de turno";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tipo-turno-index.css" asp-append-version="true" />
}

<form id="turno-inline-token" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h2 class="h4 mb-1 turno-title">Tipos de turno</h2>
            <div class="text-muted turno-subtitle">Gestiona los rangos horarios disponibles</div>
        </div>
        <a asp-action="Create" class="btn app-btn-primary turno-cta">Nuevo turno</a>
    </div>

    <div class="card shadow-sm turno-card">
        <div class="card-body p-0">
            <div class="table-responsive turno-table-wrap">
                <table class="table align-middle mb-0 turno-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Horario</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var turno in Model)
                            {
                                <tr class="turno-row"
                                    data-turno-id="@turno.TipoTurnoId"
                                    data-nombre="@turno.NombreTurno"
                                    data-hora-inicio="@turno.HoraInicio.ToString("HH:mm")"
                                    data-hora-fin="@turno.HoraFin.ToString("HH:mm")"
                                    data-activo="@turno.Activo">
                                    <td>
                                        <div class="turno-name-wrap">
                                            <button type="button"
                                                    class="btn btn-outline-secondary turno-inline-edit turno-expand-btn"
                                                    aria-label="Expandir fila"
                                                    aria-expanded="false"
                                                    aria-controls="turno-edit-@turno.TipoTurnoId">
                                                <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                    <path d="M6.7 9.3a1 1 0 0 1 1.4 0L12 13.2l3.9-3.9a1 1 0 1 1 1.4 1.4l-4.6 4.6a1 1 0 0 1-1.4 0l-4.6-4.6a1 1 0 0 1 0-1.4Z" />
                                                </svg>
                                            </button>
                                            <span class="turno-cell" data-field-display="NombreTurno">@turno.NombreTurno</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="turno-cell" data-field-display="Horario">@turno.HoraInicio.ToString("HH:mm") - @turno.HoraFin.ToString("HH:mm")</span>
                                    </td>
                                    <td>
                                        <span class="badge @(turno.Activo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") turno-cell" data-field-display="Activo">
                                            @(turno.Activo ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="btn btn-outline-danger turno-delete-btn"
                                                aria-label="Eliminar turno"
                                                data-bs-toggle="modal"
                                                data-bs-target="#turno-delete-modal"
                                                data-turno-id="@turno.TipoTurnoId"
                                                data-turno-nombre="@turno.NombreTurno">
                                            <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 6h2v9h-2V9Zm4 0h2v9h-2V9ZM7 9h2v9H7V9Z" />
                                            </svg>
                                        </button>
                                        <span class="turno-inline-status" aria-live="polite"></span>
                                    </td>
                                </tr>
                                <tr class="turno-edit-row" data-turno-edit-for="@turno.TipoTurnoId" id="turno-edit-@turno.TipoTurnoId">
                                    <td colspan="4">
                                        <div class="turno-edit-panel">
                                            <div class="turno-edit-header">
                                                <div>
                                                    <strong>Editar turno</strong>
                                                    <span class="text-muted">Actualiza los datos y guarda cambios.</span>
                                                </div>
                                            </div>
                                            <div class="row g-3 turno-edit-grid">
                                                <div class="col-md-3">
                                                    <label class="form-label turno-edit-label">Nombre</label>
                                                    <input class="form-control turno-edit-input" data-field="NombreTurno" value="@turno.NombreTurno" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label turno-edit-label">Hora inicio</label>
                                                    <input class="form-control turno-edit-input" type="time" data-field="HoraInicio" value="@turno.HoraInicio.ToString("HH:mm")" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label turno-edit-label">Hora fin</label>
                                                    <input class="form-control turno-edit-input" type="time" data-field="HoraFin" value="@turno.HoraFin.ToString("HH:mm")" />
                                                </div>
                                                <div class="col-md-5">
                                                    <label class="form-label turno-edit-label">Estado</label>
                                                    <div class="form-check form-switch turno-switch turno-edit-switch">
                                                        <input class="form-check-input" type="checkbox" role="switch" data-field="Activo" @(turno.Activo ? "checked" : null) />
                                                        <span>@(turno.Activo ? "Activo" : "Inactivo")</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="turno-edit-actions">
                                                <button type="button" class="btn btn-outline-secondary turno-inline-cancel">Cancelar</button>
                                                <button type="button" class="btn btn-primary turno-inline-save">Guardar cambios</button>
                                                <span class="turno-inline-status" aria-live="polite"></span>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No hay tipos de turno registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="turno-delete-modal" tabindex="-1" aria-labelledby="turno-delete-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="turno-delete-modal-label">Eliminar turno</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Esta acci&oacute;n elimina el turno y sus registros asociados.</p>
                <p class="mb-0">Deseas eliminar a <strong data-turno-delete-name>este turno</strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="turno-delete-form" asp-action="Delete" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/tipo-turno-inline-edit.js" asp-append-version="true"></script>
    @if (TempData["Success"] is string successMessage)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                window.AppToast?.show(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)), "success");
            });
        </script>
    }
    @if (TempData["Error"] is string errorMessage)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                window.AppToast?.show(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMessage)), "danger");
            });
        </script>
    }
}
