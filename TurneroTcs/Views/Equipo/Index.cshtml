@model IEnumerable<TurneroTcs.Models.Equipo>
@{
    ViewData["Title"] = "Turnero | Equipos";
    var equipos = Model?.ToList() ?? new List<TurneroTcs.Models.Equipo>();
    var grupos = ViewBag.Grupos as IEnumerable<TurneroTcs.Models.Grupo> ?? Enumerable.Empty<TurneroTcs.Models.Grupo>();
    var tiposTurno = ViewBag.TipoTurnos as IEnumerable<TurneroTcs.Models.TipoTurno> ?? Enumerable.Empty<TurneroTcs.Models.TipoTurno>();
    var equipoTipoTurnos = ViewBag.EquipoTipoTurnos as IDictionary<string, HashSet<string>> ?? new Dictionary<string, HashSet<string>>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/equipo-index.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/equipo-inline-edit.js" asp-append-version="true"></script>
    <script src="~/js/grupo-inline-edit.js" asp-append-version="true"></script>
    <script src="~/js/equipo-grupo-split.js" asp-append-version="true"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (!window.bootstrap?.Tooltip) return;
            document.querySelectorAll(".has-tooltip").forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}

<form id="equipo-inline-token" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<form id="grupo-inline-token" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <h2 class="h4 mb-1 equipo-title">Equipos y grupos</h2>
            <div class="text-muted equipo-subtitle">Gestiona equipos y grupos en un solo lugar</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Create" class="btn app-btn-primary equipo-cta">Nuevo equipo</a>
            <button type="button" class="btn app-btn-secondary grupo-cta" id="grupo-create-trigger">Nuevo grupo</button>
        </div>
    </div>

    <div class="row g-4 equipo-grupo-grid">
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm equipo-card">
                <div class="card-body p-0">
                    @if (equipos.Any())
                    {
                        <div class="table-responsive equipo-table-wrap">
                            <table class="table align-middle mb-0 equipo-table">
                                <thead>
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Estado</th>
                                        <th>Creado en</th>
                                        <th class="text-end">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var equipo in equipos)
                                    {
                                        <tr class="equipo-row"
                                            data-equipo-id="@equipo.EquipoId"
                                            data-nombre="@equipo.NombreEquipo"
                                            data-activo="@equipo.Activo"
                                            data-tipo-generacion="@equipo.TipoGeneracion">
                                            <td class="equipo-name-cell">
                                                <div class="equipo-name-wrap">
                                                    <button type="button"
                                                            class="btn btn-outline-secondary equipo-inline-edit equipo-expand-btn has-tooltip"
                                                            aria-label="Expandir fila"
                                                            aria-expanded="false"
                                                            aria-controls="equipo-edit-@equipo.EquipoId"
                                                            title="Editar equipo">
                                                        <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                            <path d="M7.4 8.6 12 13.2l4.6-4.6 1.4 1.4-6 6-6-6z" />
                                                        </svg>
                                                    </button>
                                                    <span class="equipo-cell" data-field-display="NombreEquipo">@equipo.NombreEquipo</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge @(equipo.Activo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") equipo-cell" data-field-display="Activo">
                                                    @(equipo.Activo ? "Activo" : "Inactivo")
                                                </span>
                                            </td>
                                            <td>
                                                @equipo.CreadoEn.ToString("yyyy-MM-dd")
                                            </td>
                                            <td class="text-end">
                                                <a asp-controller="Planificacion"
                                                   asp-action="Index"
                                                   asp-route-equipoId="@equipo.EquipoId"
                                                   class="btn btn-outline-secondary equipo-settings-btn has-tooltip"
                                                   aria-label="Abrir planificacion"
                                                   title="Planificacion">
                                                    <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                        <path d="M19.14 12.94c.04-.31.06-.63.06-.94s-.02-.63-.07-.94l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.52 7.52 0 0 0-1.63-.94l-.36-2.54A.5.5 0 0 0 13.9 1h-3.8a.5.5 0 0 0-.49.41l-.36 2.54c-.58.22-1.12.52-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.62 7.48a.5.5 0 0 0 .12.64l2.03 1.58c-.05.31-.07.63-.07.94s.02.63.07.94l-2.03 1.58a.5.5 0 0 0-.12.64l1.92 3.32c.13.22.39.31.6.22l2.39-.96c.5.41 1.05.73 1.63.94l.36 2.54c.04.24.25.41.49.41h3.8c.24 0 .45-.17.49-.41l.36-2.54c.58-.22 1.12-.52 1.63-.94l2.39.96c.22.09.47 0 .6-.22l1.92-3.32a.5.5 0 0 0-.12-.64l-2.03-1.58ZM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2Z" />
                                                    </svg>
                                                </a>
                                                @if (User.IsInRole("SuperAdmin"))
                                                {
                                                    <a asp-action="DescargarConfiguracion"
                                                       asp-route-equipoId="@equipo.EquipoId"
                                                       class="btn btn-outline-secondary equipo-download-btn has-tooltip"
                                                       aria-label="Descargar configuracion"
                                                       title="Descargar configuracion">
                                                        <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                            <path d="M12 3a1 1 0 0 1 1 1v9.17l3.59-3.58 1.41 1.41L12 17l-6-6 1.41-1.41L11 13.17V4a1 1 0 0 1 1-1Zm-7 16h14v2H5v-2Z" />
                                                        </svg>
                                                    </a>
                                                }
                                                <button type="button"
                                                        class="btn btn-outline-danger equipo-delete-btn has-tooltip"
                                                        aria-label="Eliminar equipo"
                                                        title="Eliminar"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#equipo-delete-modal"
                                                        data-equipo-id="@equipo.EquipoId"
                                                        data-equipo-nombre="@equipo.NombreEquipo">
                                                    <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                        <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 6h2v9h-2V9Zm4 0h2v9h-2V9ZM7 9h2v9H7V9Z" />
                                                    </svg>
                                                </button>
                                                <span class="equipo-inline-status" aria-live="polite"></span>
                                            </td>
                                        </tr>
                                        <tr class="equipo-edit-row" data-equipo-edit-for="@equipo.EquipoId" id="equipo-edit-@equipo.EquipoId">
                                            <td colspan="4">
                                                <div class="equipo-edit-panel">
                                                    <div class="equipo-edit-header">
                                                        <div>
                                                            <strong>Editar equipo</strong>
                                                            <span class="text-muted">Actualiza los datos y guarda cambios.</span>
                                                        </div>
                                                    </div>
                                                    <div class="row g-3 equipo-edit-grid">
                                                        <div class="col-md-6">
                                                            <label class="form-label equipo-edit-label">Nombre equipo</label>
                                                            <input class="form-control equipo-edit-input" data-field="NombreEquipo" value="@equipo.NombreEquipo" />
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label equipo-edit-label">Estado</label>
                                                            <div class="form-check form-switch equipo-switch equipo-edit-switch">
                                                                <input class="form-check-input" type="checkbox" role="switch" data-field="Activo" @(equipo.Activo ? "checked" : null) />
                                                                <span>@(equipo.Activo ? "Activo" : "Inactivo")</span>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label equipo-edit-label">Tipo de generacion</label>
                                                            <select class="form-select equipo-edit-input" data-field="TipoGeneracion">
                                                                <option value="Rotacion" selected="@(equipo.TipoGeneracion == "Rotacion" ? "selected" : null)">Rotacion</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin") || User.IsInRole("Lider"))
                                                    {
                                                        var selectedTurnos = equipoTipoTurnos.TryGetValue(equipo.EquipoId, out var mapped)
                                                            ? mapped
                                                            : new HashSet<string>();
                                                        <div class="equipo-turnos-panel">
                                                            <div class="equipo-turnos-header">
                                                                <div>
                                                                    <strong>Tipos de turno</strong>
                                                                    <span class="text-muted">Selecciona los turnos disponibles para este equipo.</span>
                                                                </div>
                                                            </div>
                                                            @if (tiposTurno.Any())
                                                            {
                                                                <div class="equipo-turnos-grid">
                                                                    @foreach (var turno in tiposTurno)
                                                                    {
                                                                        var isChecked = selectedTurnos.Contains(turno.TipoTurnoId);
                                                                        <label class="equipo-turno-pill">
                                                                            <input type="checkbox" name="tipoTurnoIds" value="@turno.TipoTurnoId" checked="@(isChecked ? "checked" : null)" />
                                                                            <span>@turno.NombreTurno (@turno.HoraInicio.ToString("HH\\:mm")-@turno.HoraFin.ToString("HH\\:mm"))</span>
                                                                        </label>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="text-muted">No hay tipos de turno registrados.</div>
                                                            }
                                                        </div>
                                                    }
                                                    <div class="equipo-edit-actions">
                                                        <button type="button" class="btn btn-outline-secondary equipo-inline-cancel">Cancelar</button>
                                                        <button type="button" class="btn btn-primary equipo-inline-save">Guardar cambios</button>
                                                        <span class="equipo-inline-status" aria-live="polite"></span>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="equipo-empty">
                            <p class="equipo-empty-title">Todavia no hay equipos</p>
                            <p class="equipo-empty-subtitle">Crea el primer equipo para comenzar a asignar personas.</p>
                            <a asp-action="Create" class="btn btn-primary equipo-cta">Crear equipo</a>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm grupo-card grupo-panel">
                <div class="card-body p-0">
                    <div class="table-responsive grupo-table-wrap">
                        <table class="table align-middle mb-0 grupo-table">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Equipo</th>
                                    <th>Estado</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="grupo-create-row" data-grupo-create>
                                    <td colspan="4">
                                        <form asp-controller="Grupo" asp-action="CreateInline" method="post" class="grupo-edit-panel grupo-create-panel grupo-create-form">
                                            @Html.AntiForgeryToken()
                                            <div class="grupo-edit-header">
                                                <div>
                                                    <strong>Nuevo grupo</strong>
                                                    <span class="text-muted">Crea un grupo para el equipo seleccionado.</span>
                                                </div>
                                            </div>
                                            <div class="row g-3 grupo-edit-grid">
                                                <div class="col-md-4">
                                                    <label class="form-label grupo-edit-label">Nombre grupo</label>
                                                    <input class="form-control grupo-edit-input" name="nombreGrupo" />
                                                </div>
                                                <div class="col-md-3 d-none">
                                                    <label class="form-label grupo-edit-label">Equipo</label>
                                                    <select class="form-select grupo-edit-input" name="equipoId" data-create-field="EquipoId">
                                                        @foreach (var equipo in equipos)
                                                        {
                                                            <option value="@equipo.EquipoId">@equipo.NombreEquipo</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-4">
                                                    <label class="form-label grupo-edit-label">Estado</label>
                                                    <div class="form-check form-switch grupo-switch grupo-edit-switch">
                                                        <input class="form-check-input" type="checkbox" role="switch" name="activo" checked />
                                                        <span>Activo</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="grupo-edit-actions">
                                                <button type="button" class="btn btn-outline-secondary grupo-create-cancel">Cancelar</button>
                                                <button type="submit" class="btn btn-primary">Crear grupo</button>
                                                <span class="grupo-inline-status" aria-live="polite"></span>
                                            </div>
                                        </form>
                                    </td>
                                </tr>
                                @if (grupos.Any())
                                {
                                    foreach (var grupo in grupos)
                                    {
                                        <tr class="grupo-row"
                                            data-grupo-id="@grupo.GrupoId"
                                            data-nombre="@grupo.NombreGrupo"
                                            data-equipo-id="@grupo.EquipoId"
                                            data-activo="@grupo.Activo">
                                            <td>
                                                <div class="grupo-name-wrap">
                                                    <button type="button"
                                                            class="btn btn-outline-secondary grupo-inline-edit grupo-expand-btn has-tooltip"
                                                            aria-label="Expandir fila"
                                                            aria-expanded="false"
                                                            aria-controls="grupo-edit-@grupo.GrupoId"
                                                            title="Editar grupo">
                                                        <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                            <path d="M7.4 8.6 12 13.2l4.6-4.6 1.4 1.4-6 6-6-6z" />
                                                        </svg>
                                                    </button>
                                                    <span class="grupo-cell" data-field-display="NombreGrupo">@grupo.NombreGrupo</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="grupo-cell" data-field-display="Equipo">@(grupo.Equipo?.NombreEquipo ?? grupo.EquipoId)</span>
                                            </td>
                                            <td>
                                                <span class="badge @(grupo.Activo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary") grupo-cell" data-field-display="Activo">
                                                    @(grupo.Activo ? "Activo" : "Inactivo")
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                @if (grupo.Activo && (User.IsInRole("SuperAdmin") || User.IsInRole("Admin")))
                                                {
                                                    <button type="button"
                                                            class="btn btn-outline-danger grupo-delete-btn has-tooltip"
                                                            aria-label="Desactivar grupo"
                                                            title="Desactivar"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#grupo-delete-modal"
                                                            data-grupo-id="@grupo.GrupoId"
                                                            data-grupo-nombre="@grupo.NombreGrupo">
                                                        <svg aria-hidden="true" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                                                            <path d="M9 3h6l1 2h4v2H4V5h4l1-2Zm1 6h2v9h-2V9Zm4 0h2v9h-2V9ZM7 9h2v9H7V9Z" />
                                                        </svg>
                                                    </button>
                                                }
                                                <span class="grupo-inline-status" aria-live="polite"></span>
                                            </td>
                                        </tr>
                                        <tr class="grupo-edit-row" data-grupo-edit-for="@grupo.GrupoId" data-equipo-id="@grupo.EquipoId" id="grupo-edit-@grupo.GrupoId">
                                            <td colspan="4">
                                                <div class="grupo-edit-panel">
                                                    <div class="grupo-edit-header">
                                                        <div>
                                                            <strong>Editar grupo</strong>
                                                            <span class="text-muted">Actualiza los datos y guarda cambios.</span>
                                                        </div>
                                                    </div>
                                                    <div class="row g-3 grupo-edit-grid">
                                                        <div class="col-md-4">
                                                            <label class="form-label grupo-edit-label">Nombre grupo</label>
                                                            <input class="form-control grupo-edit-input" data-field="NombreGrupo" value="@grupo.NombreGrupo" />
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label grupo-edit-label">Equipo</label>
                                                            <select class="form-select grupo-edit-input" data-field="EquipoId">
                                                                @foreach (var equipo in equipos)
                                                                {
                                                                    <option value="@equipo.EquipoId" selected="@(equipo.EquipoId == grupo.EquipoId ? "selected" : null)">
                                                                        @equipo.NombreEquipo
                                                                    </option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <label class="form-label grupo-edit-label">Estado</label>
                                                            <div class="form-check form-switch grupo-switch grupo-edit-switch">
                                                                <input class="form-check-input" type="checkbox" role="switch" data-field="Activo" @(grupo.Activo ? "checked" : null) />
                                                                <span>@(grupo.Activo ? "Activo" : "Inactivo")</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="grupo-edit-actions">
                                                        <button type="button" class="btn btn-outline-secondary grupo-inline-cancel">Cancelar</button>
                                                        <button type="button" class="btn btn-primary grupo-inline-save">Guardar cambios</button>
                                                        <span class="grupo-inline-status" aria-live="polite"></span>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                <tr class="grupo-empty-row" data-grupo-empty>
                                    <td colspan="4" class="text-center text-muted py-4">
                                        No hay grupos registrados.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="equipo-delete-modal" tabindex="-1" aria-labelledby="equipo-delete-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="equipo-delete-modal-label">Eliminar equipo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Esta acci&oacute;n elimina el equipo y todos sus registros asociados.</p>
                <p class="mb-0">Deseas eliminar a <strong data-equipo-delete-name>este equipo</strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="equipo-delete-form" asp-action="Delete" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="grupo-delete-modal" tabindex="-1" aria-labelledby="grupo-delete-modal-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="grupo-delete-modal-label">Desactivar grupo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Esta acci&oacute;n desactiva el grupo y lo excluye de la generaci&oacute;n de horarios.</p>
                <p class="mb-0">Deseas desactivar a <strong data-grupo-delete-name>este grupo</strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="grupo-delete-form" asp-controller="Grupo" asp-action="Delete" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Desactivar</button>
                </form>
            </div>
        </div>
    </div>
</div>
