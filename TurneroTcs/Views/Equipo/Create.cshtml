@model TurneroTcs.ViewModels.EquipoViewModel
@{
    ViewData["Title"] = "Turnero | Crear Equipo";
}

@section Styles {
    <link rel="stylesheet" href="~/css/equipo-create.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm equipo-create-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <span class="badge bg-primary-subtle text-primary border border-primary equipo-create-badge">Nuevo</span>
                        </div>
                        <div>
                            <h2 class="h4 mb-1 equipo-create-title">Crear equipo</h2>
                            <div class="text-muted equipo-create-subtitle">Registra un nuevo equipo</div>
                        </div>
                    </div>

                    <form asp-action="Create" method="post" class="mt-3">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="NombreEquipo" class="form-label equipo-create-label"></label>
                            <input asp-for="NombreEquipo" class="form-control equipo-create-input" />
                            <span asp-validation-for="NombreEquipo" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary equipo-create-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary equipo-create-primary">Crear</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
